# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/propinspect

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# AI Models Configuration
YOLO_MODEL_PATH=yolo11x.pt
YOLO_CONFIDENCE_THRESHOLD=0.35
YOLO_IOU_THRESHOLD=0.45
YOLO_DEVICE=auto

# Qwen Vision-Language Model
QWEN_MODEL_PATH=Qwen/Qwen2.5-VL-7B-Instruct
USE_QWEN_API=true
QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=your-qwen-api-key-here

# OpenAI (Optional Fallback)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Processing Settings
FRAME_INTERVAL_SECONDS=2.0
MAX_FRAMES_PER_VIDEO=150
BATCH_SIZE=8

# Storage Configuration
USE_LOCAL_STORAGE=true
UPLOAD_DIR=temp_uploads
FRAMES_DIR=temp_frames
REPORTS_DIR=temp_reports
EVIDENCE_DIR=temp_evidence

# S3/R2 Storage (if USE_LOCAL_STORAGE=false)
S3_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=propinspect-videos
S3_REGION_NAME=us-east-1

# Clerk Authentication (Optional)
CLERK_SECRET_KEY=your-clerk-secret-key
CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key

# Admin User
FIRST_SUPERUSER_EMAIL=admin@propinspect.com
FIRST_SUPERUSER_PASSWORD=ChangeThisPassword123!

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
